{
  "name": "rlm_chunk",
  "description": "Paginated RLM chunks.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "file_pattern": {
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "default": 5,
        "format": "uint",
        "minimum": 0,
        "type": "integer"
      },
      "offset": {
        "default": 0,
        "format": "uint",
        "minimum": 0,
        "type": "integer"
      },
      "session_id": {
        "type": "string"
      }
    },
    "required": [
      "session_id"
    ],
    "title": "RlmChunkArgs",
    "type": "object"
  }
}